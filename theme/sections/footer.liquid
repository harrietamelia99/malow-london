<footer class="footer">
  <div class="container">
    <div class="footer__inner">

      <!-- Monogram -->
      <div>
        <img src="{{ 'malow-footer-mark.svg' | asset_url }}" alt="MALOW London" class="footer__monogram-img" width="320" height="300">
      </div>

      <!-- Navigation links -->
      <div>
        <p class="footer__col-heading">Explore MALOW</p>
        <ul class="footer__links">
          <li><a href="{{ routes.root_url }}pages/size-guide" class="footer__link">Size Guide</a></li>
          <li><a href="{{ routes.root_url }}pages/shipping" class="footer__link">Shipping</a></li>
          <li><a href="{{ routes.root_url }}policies/privacy-policy" class="footer__link">Privacy Policy</a></li>
          <li><a href="{{ routes.root_url }}pages/cookies-policy" class="footer__link">Cookies Policy</a></li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <p class="footer__col-heading">Follow MALOW</p>
        <ul class="footer__social" role="list">
          <li>
            <a href="https://www.instagram.com/malow_london/" class="footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="MALOW London on Instagram">
              <svg class="footer__social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="1.25" fill="currentColor" stroke="none"/>
              </svg>
            </a>
          </li>
          <li>
            <a href="https://www.facebook.com/profile.php?id=61587376413676" class="footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="MALOW London on Facebook">
              <svg class="footer__social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          </li>
          <li>
            <a href="https://www.tiktok.com/@malow_london" class="footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="MALOW London on TikTok">
              <svg class="footer__social-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
              </svg>
            </a>
          </li>
        </ul>
      </div>

    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">&copy; {{ 'now' | date: '%Y' }} MALOW London. All rights reserved.</p>
      <p class="footer__credit">Made by <a href="https://www.collectivstudio.uk/" target="_blank" rel="noopener noreferrer">Collectiv Studio</a></p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "MALOW Footer",
  "settings": []
}
{% endschema %}
