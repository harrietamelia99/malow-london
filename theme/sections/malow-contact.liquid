<section class="info-hero">
  <div class="container info-hero__inner">
    <span class="info-hero__kicker">We'd love to hear from you</span>
    <h1 class="info-hero__title">Get In Touch</h1>
    <p class="info-hero__sub">Our team is available Monday–Friday, 9am–5pm GMT.<br>We aim to respond within 24 hours.</p>
  </div>
</section>

<section class="section contact-layout">
  <div class="container contact-layout__inner">

    <!-- Contact form (uses Shopify's built-in /contact form endpoint) -->
    <div class="contact-form-wrap">
      <h2 class="contact-form__heading">Send us a message</h2>

      {%- form 'contact', id: 'malow-contact-form', class: 'contact-form' -%}

        {%- if form.posted_successfully? -%}
          <p class="contact-form__success" role="status">Thank you — we'll be in touch shortly.</p>
        {%- endif -%}

        {%- if form.errors -%}
          <p class="contact-form__error" role="alert">{{ form.errors | default_errors }}</p>
        {%- endif -%}

        <div class="contact-form__row contact-form__row--split">
          <div class="contact-form__field">
            <label class="contact-form__label" for="contact-name">Full name</label>
            <input class="contact-form__input" type="text" id="contact-name" name="contact[name]"
              placeholder="Jane Smith" autocomplete="name" required
              value="{{ form.name }}">
          </div>
          <div class="contact-form__field">
            <label class="contact-form__label" for="contact-email">Email address</label>
            <input class="contact-form__input" type="email" id="contact-email" name="contact[email]"
              placeholder="jane@example.com" autocomplete="email" required
              value="{{ form.email }}">
          </div>
        </div>

        <div class="contact-form__field">
          <label class="contact-form__label" for="contact-subject">Subject</label>
          <select class="contact-form__input contact-form__select" id="contact-subject" name="contact[subject]">
            <option value="" disabled selected>Select a topic…</option>
            <option value="Order enquiry">Order enquiry</option>
            <option value="Returns & exchanges">Returns &amp; exchanges</option>
            <option value="Sizing help">Sizing help</option>
            <option value="Wholesale">Wholesale</option>
            <option value="Press & media">Press &amp; media</option>
            <option value="Something else">Something else</option>
          </select>
        </div>

        <div class="contact-form__field">
          <label class="contact-form__label" for="contact-order">Order number <span class="contact-form__optional">(optional)</span></label>
          <input class="contact-form__input" type="text" id="contact-order"
            name="contact[order_number]" placeholder="e.g. #1234">
        </div>

        <div class="contact-form__field">
          <label class="contact-form__label" for="contact-message">Your message</label>
          <textarea class="contact-form__input contact-form__textarea" id="contact-message"
            name="contact[body]" placeholder="Tell us how we can help…" rows="6" required>{{ form.body }}</textarea>
        </div>

        <button type="submit" class="btn-rect contact-form__submit">Send message</button>

      {%- endform -%}
    </div>

    <!-- Contact info cards -->
    <div class="contact-info">

      <div class="contact-card">
        <div class="contact-card__icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <div>
          <p class="contact-card__label">Customer support</p>
          <a href="mailto:support@malowlondon.com" class="contact-card__value">support@malowlondon.com</a>
        </div>
      </div>

      <div class="contact-card">
        <div class="contact-card__icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div>
          <p class="contact-card__label">Customer care hours</p>
          <p class="contact-card__value">Mon–Fri, 9am–5pm GMT</p>
        </div>
      </div>

      <div class="contact-card">
        <div class="contact-card__icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div>
          <p class="contact-card__label">Based in</p>
          <p class="contact-card__value">London, United Kingdom</p>
        </div>
      </div>

      <div class="contact-card">
        <div class="contact-card__icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.42 2 2 0 0 1 3.59 1.25h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.81a16 16 0 0 0 6 6l.88-.88a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/></svg>
        </div>
        <div>
          <p class="contact-card__label">Press &amp; partnerships</p>
          <a href="mailto:press@malowlondon.com" class="contact-card__value">press@malowlondon.com</a>
        </div>
      </div>

    </div>
  </div>
</section>

<section class="section contact-faq">
  <div class="container contact-faq__inner">
    <h2 class="contact-faq__heading">Frequently asked questions</h2>
    <div class="faq-list">

      <details class="faq-item">
        <summary class="faq-item__q">How long will my order take to arrive?</summary>
        <div class="faq-item__a"><p>We ship with Evri. Estimated transit after dispatch: UK 1–3 working days; Northern Ireland 3–5; EU 5–8; US 7–10. See our <a href="{{ routes.root_url }}pages/shipping" class="faq-item__link">shipping page</a> for full details.</p></div>
      </details>

      <details class="faq-item">
        <summary class="faq-item__q">Can I return or exchange my shoes?</summary>
        <div class="faq-item__a"><p>Yes. We accept returns within 14 days of delivery, provided items are unworn and in original packaging. Visit our <a href="{{ routes.root_url }}pages/shipping" class="faq-item__link">Shipping &amp; Returns</a> page for full details.</p></div>
      </details>

      <details class="faq-item">
        <summary class="faq-item__q">I'm not sure about my size — what should I do?</summary>
        <div class="faq-item__a"><p>Our styles run true to size. You can find our full UK, EU, and US conversion chart on the <a href="{{ routes.root_url }}pages/size-guide" class="faq-item__link">Size Guide</a> page.</p></div>
      </details>

      <details class="faq-item">
        <summary class="faq-item__q">Where is my order?</summary>
        <div class="faq-item__a"><p>Once your order has been dispatched, you'll receive a confirmation email with a tracking link. If you haven't received this within 24 hours, please get in touch with your order number.</p></div>
      </details>

      <details class="faq-item">
        <summary class="faq-item__q">Do you ship internationally?</summary>
        <div class="faq-item__a"><p>Yes — we ship worldwide. Standard rates by region are on our <a href="{{ routes.root_url }}pages/shipping" class="faq-item__link">shipping page</a>. Customs duties and taxes may apply.</p></div>
      </details>

      <details class="faq-item">
        <summary class="faq-item__q">Can I change or cancel my order?</summary>
        <div class="faq-item__a"><p>We process orders quickly, but if you need to make a change, please email <a href="mailto:support@malowlondon.com" class="faq-item__link">support@malowlondon.com</a> as soon as possible with your order number.</p></div>
      </details>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "MALOW Contact",
  "tag": "div",
  "settings": [],
  "presets": [{ "name": "MALOW Contact" }]
}
{% endschema %}
