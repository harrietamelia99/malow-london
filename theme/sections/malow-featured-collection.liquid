{%- assign collection = collections[section.settings.collection] -%}

<section class="shop-all section" aria-labelledby="shop-all-heading-{{ section.id }}">
  <div class="container">
    <div class="section-header">
      <h2 class="section-heading" id="shop-all-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
      <a href="/collections/shop-all" class="btn-pill">{{ section.settings.cta_label }}</a>
    </div>

    <div class="product-grid">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          {%- render 'malow-product-card', product: product -%}
        {%- else -%}
          {%- for i in (1..4) -%}
            <div class="product-card product-card--placeholder">
              <div class="product-card__image-wrap">
                {{ 'product-apparel-' | append: i | placeholder_svg_tag: 'product-card__img' }}
              </div>
              <div class="product-card__info">
                <p class="product-card__name">Sample Heel</p>
                <p class="product-card__price">£75.00</p>
              </div>
            </div>
          {%- endfor -%}
        {%- endfor -%}
      {%- else -%}
        {%- for product in collections.all.products limit: section.settings.products_to_show -%}
          {%- render 'malow-product-card', product: product -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MALOW Featured Collection",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop All"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "View All"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 2,
      "default": 8,
      "label": "Products to show"
    }
  ],
  "presets": [{ "name": "MALOW Featured Collection" }]
}
{% endschema %}
