<section class="instagram-preview section" aria-labelledby="instagram-heading-{{ section.id }}">
  <div class="container">
    <header class="instagram-preview__intro">
      <span class="instagram-preview__kicker">@malow_london</span>
      <h2 class="instagram-preview__title" id="instagram-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
      <p class="instagram-preview__sub">{{ section.settings.subheading }}</p>
      <a href="https://www.instagram.com/malow_london/" class="btn-pill instagram-preview__cta" target="_blank" rel="noopener noreferrer">{{ section.settings.cta_label }}</a>
    </header>

    <div class="instagram-preview__grid" role="list">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: 'https://www.instagram.com/malow_london/' }}"
          class="instagram-preview__tile"
          role="listitem"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="{{ block.settings.alt | default: 'MALOW on Instagram' | escape }}"
          {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 600 }}"
              alt="{{ block.settings.alt | default: 'MALOW London on Instagram' | escape }}"
              loading="lazy"
              width="600" height="600">
          {%- else -%}
            <img
              src="{{ 'instagram-preview-' | append: forloop.index | append: '.png' | asset_url }}"
              alt="MALOW London on Instagram"
              loading="lazy"
              width="600" height="600">
          {%- endif -%}
        </a>
      {%- else -%}
        {%- for i in (1..3) -%}
          <a href="https://www.instagram.com/malow_london/" class="instagram-preview__tile" role="listitem" target="_blank" rel="noopener noreferrer">
            <img src="{{ 'instagram-preview-' | append: i | append: '.png' | asset_url }}" alt="MALOW London on Instagram" loading="lazy" width="600" height="600">
          </a>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MALOW Instagram",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "On Instagram"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Behind the scenes from our studio — new styles, fittings, and how you wear MALOW."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Follow us"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Instagram image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Instagram post URL"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "MALOW Instagram" }]
}
{% endschema %}
